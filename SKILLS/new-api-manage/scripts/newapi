    price-estimation) deployments_price_estimation_cmd "$@" ;;
    check-name) deployments_check_name_cmd "$@" ;;
    test-connection) deployments_test_connection_cmd "$@" ;;
    *) err "deployments expects: settings|list|search|get|create|update|update-name|extend|delete|logs|containers|container|hardware-types|locations|available-replicas|price-estimation|check-name|test-connection"; return 1 ;;
  esac
}

login_cmd() {
  local username=""
  local password=""
  local turnstile=""
  local jar="${NEW_API_COOKIE_JAR:-}"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --username)
        username="$2"; shift 2 ;;
      --password)
        password="$2"; shift 2 ;;
      --turnstile)
        turnstile="$2"; shift 2 ;;
      --cookie-jar)
        jar="$2"; shift 2 ;;
      -h|--help)
        usage; return 0 ;;
      *)
        err "unknown arg: $1"
        return 1
        ;;
    esac
  done

  if [[ -z "$username" || -z "$password" ]]; then
    err "login requires --username and --password"
    return 1
  fi
  require_base_url
  if [[ -z "$jar" ]]; then
    err "login requires NEW_API_COOKIE_JAR or --cookie-jar"
    return 1
  fi

  local base
  base="$(trim_trailing_slash "$NEW_API_BASE_URL")"
  local url="$base/api/user/login"
  if [[ -n "$turnstile" ]]; then
    url="$url?turnstile=$turnstile"
  fi

  local -a curl_args
  mapfile -t curl_args < <(curl_base_args)

  curl "${curl_args[@]}" \
    -X POST "$url" \
    -c "$jar" -b "$jar" \
    -H 'Content-Type: application/json' \
    --data-binary "$(jq -nc --arg u "$username" --arg p "$password" '{username:$u,password:$p}')" \
    | (command -v jq >/dev/null 2>&1 && jq . || cat)
}

login2fa_cmd() {
  local code=""
  local jar="${NEW_API_COOKIE_JAR:-}"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --code)
        code="$2"; shift 2 ;;
      --cookie-jar)
        jar="$2"; shift 2 ;;
      -h|--help)
        usage; return 0 ;;
      *)
        err "unknown arg: $1"
        return 1
        ;;
    esac
  done

  if [[ -z "$code" ]]; then
    err "login2fa requires --code"
    return 1
  fi
  require_base_url
  if [[ -z "$jar" ]]; then
    err "login2fa requires NEW_API_COOKIE_JAR or --cookie-jar"
    return 1
  fi

  local base
  base="$(trim_trailing_slash "$NEW_API_BASE_URL")"
  local url="$base/api/user/login/2fa"

  local -a curl_args
  mapfile -t curl_args < <(curl_base_args)

  curl "${curl_args[@]}" \
    -X POST "$url" \
    -c "$jar" -b "$jar" \
    -H 'Content-Type: application/json' \
    --data-binary "$(jq -nc --arg c "$code" '{code:$c}')" \
    | (command -v jq >/dev/null 2>&1 && jq . || cat)
}

main() {
  # Global options
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --config)
        NEW_API_CONFIG="$2"; shift 2 ;;
      --insecure)
        NEW_API_INSECURE=true; shift ;;
      -h|--help)
        usage; return 0 ;;
      *)
        break
        ;;
    esac
  done

  load_config_if_any || true

  local cmd="${1:-}"
  case "$cmd" in
    doctor)
      shift
      doctor_cmd "$@"
      ;;
    call)
      shift
      call_cmd "$@"
      ;;
    routes)
      shift
      routes_cmd "$@"
      ;;
    channel)
      shift
      channel_cmd "$@"
      ;;
    token)
      shift
      token_cmd "$@"
      ;;
    user)
      shift
      user_cmd "$@"
      ;;
    option)
      shift
      option_cmd "$@"
      ;;
    models)
      shift
      models_cmd "$@"
      ;;
    vendors)
      shift
      vendors_cmd "$@"
      ;;
    usage)
      shift
      usage_cmd "$@"
      ;;
    log)
      shift
      log_cmd "$@"
      ;;
    data)
      shift
      data_cmd "$@"
      ;;
    group)
      shift
      group_cmd "$@"
      ;;
    prefill-group)
      shift
      prefill_group_cmd "$@"
      ;;
    mj)
      shift
      mj_cmd "$@"
      ;;
    task)
      shift
      task_cmd "$@"
      ;;
    redemption)
      shift
      redemption_cmd "$@"
      ;;
    performance)
      shift
      performance_cmd "$@"
      ;;
    ratio-sync)
      shift
      ratio_sync_cmd "$@"
      ;;
    subscription)
      shift
      subscription_cmd "$@"
      ;;
    deployments)
      shift
      deployments_cmd "$@"
      ;;
    login)
      shift
      login_cmd "$@"
      ;;
    login2fa)
      shift
      login2fa_cmd "$@"
      ;;
    -h|--help|help|"")
      usage
      ;;
    *)
      err "unknown command: $cmd"
      usage
      return 1
      ;;
  esac
}

main "$@"
