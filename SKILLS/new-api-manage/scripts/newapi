#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
newapi - production CLI helper for QuantumNous/new-api management API (/api/*)

Examples below assume you run from the skill root. If not, replace
`scripts/newapi` with the actual path to this file.

Global options (must appear before <command>)
  --config <path>       # same as NEW_API_CONFIG
  --insecure            # same as NEW_API_INSECURE=true (curl -k)

Required env
  NEW_API_BASE_URL    e.g. http://127.0.0.1:3000

Auth (choose one)
  Access Token mode:
    NEW_API_USER_ID
    NEW_API_ACCESS_TOKEN

  API Token Key mode (TokenAuthReadOnly; e.g. /api/usage/token, /api/log/token):
    NEW_API_TOKEN_KEY          # e.g. sk-xxxx

  Session mode:
    NEW_API_USER_ID
    NEW_API_COOKIE_JAR   e.g. /tmp/new-api.cookies

Optional env
  NEW_API_INSECURE=true   # curl -k
  NEW_API_CONFIG=/path/to/config.json
  NEW_API_CODE_DIR=/path/to/new-api-repo   # for route generation

Commands
  doctor [--deep] [--json]
  call <METHOD> <PATH> [--auth token|session|sk|auto|none] [--json <file>] [--data <json>] [--output pretty|raw] [--header 'K: V']
  login --username <u> --password <p> [--turnstile <token>] [--cookie-jar <path>]
  login2fa --code <totp_or_backup_code> [--cookie-jar <path>]

  routes gen [--code-dir <dir>] [--router-file <path>] [--format md|json] [--out <file>]

  channel list   [--p N] [--page-size N] [--status enabled|disabled|all] [--type N] [--id-sort] [--tag-mode]
  channel search --keyword <kw> [--group <g>] [--model <m>] [--p N] [--page-size N] [--status enabled|disabled|all] [--type N] [--id-sort] [--tag-mode]
  channel get    --id <id>
  channel create --json <file>
  channel update --json <file>
  channel delete --id <id> --yes
  channel batch-delete --ids <1,2,3> --yes
  channel batch-tag    --ids <1,2,3> --tag <tag> --yes
  channel copy   --id <id> [--suffix <s>] [--reset-balance true|false]
  channel upstream-updates detect|apply|detect-all|apply-all [...]

  token list [--p N] [--page-size N]
  token search [--keyword <kw>] [--token <partial>] [--p N] [--page-size N]
  token get --id <id>
  token create --json <file>
  token update --json <file>
  token delete --id <id> --yes
  token key --id <id> (--out <file> | --stdout)

  user self
  user list [--p N] [--page-size N]
  user search [--keyword <kw>] [--group <g>] [--p N] [--page-size N]
  user get --id <id>
  user create --json <file>
  user update --json <file>
  user manage --id <id> --action disable|enable|delete|promote|demote [--yes]
  user delete --id <id> --yes
  user oauth-bindings --id <id>
  user oauth-unbind --id <id> --provider-id <pid> --yes
  user binding-clear --id <id> --binding-type <type> --yes

  option get
  option set --key <k> --value <v>
  option reset-model-ratio --yes
  option affinity-cache stats
  option affinity-cache clear (--all | --rule-name <name>) --yes

  models list [--p N] [--page-size N]
  models search [--keyword <kw>] [--vendor <v>] [--p N] [--page-size N]
  models get --id <id>
  models create --json <file>
  models update --json <file>
  models delete --id <id> --yes
  models missing
  models sync preview [--locale <loc>]
  models sync run --json <file>

  vendors list [--p N] [--page-size N]
  vendors search [--keyword <kw>] [--p N] [--page-size N]
  vendors get --id <id>
  vendors create --json <file>
  vendors update --json <file>
  vendors delete --id <id> --yes

  # More groups (see SKILL.md / ROUTES.generated.md)
  usage | log | data | group | prefill-group | mj | task | redemption | performance | ratio-sync | subscription | deployments

Examples
  bash skills/new-api-manage/scripts/newapi call GET /api/status

  # Token auth
  export NEW_API_BASE_URL=http://127.0.0.1:3000
  export NEW_API_USER_ID=1
  export NEW_API_ACCESS_TOKEN=xxxx
  bash skills/new-api-manage/scripts/newapi call GET /api/channel/ --auth token

  # Session login (if Turnstile not required)
  export NEW_API_COOKIE_JAR=/tmp/new-api.cookies
  bash skills/new-api-manage/scripts/newapi login --username admin --password '...' | jq .

  # If 2FA is enabled, complete login in the same cookie jar
  bash skills/new-api-manage/scripts/newapi login2fa --code 123456 | jq .

  # Generate routes index from local new-api repo
  export NEW_API_CODE_DIR=/data/workspace/new-api-latest
  bash skills/new-api-manage/scripts/newapi routes gen --format md --out /tmp/routes.md

EOF
}

err() {
  echo "[newapi] $*" >&2
}

trim_trailing_slash() {
  local s="$1"
  # remove all trailing slashes
  while [[ "$s" == */ ]]; do
    s="${s%/}"
  done
  echo "$s"
}

load_config_if_any() {
  local cfg="${NEW_API_CONFIG:-}"
  if [[ -z "$cfg" ]]; then
    return 0
  fi
  if [[ ! -f "$cfg" ]]; then
    err "NEW_API_CONFIG not found: $cfg"
    return 1
  fi

  # Only fill env vars when they are not set already.
  if command -v jq >/dev/null 2>&1; then
    NEW_API_BASE_URL="${NEW_API_BASE_URL:-$(jq -r '.base_url // empty' "$cfg")}"
    NEW_API_USER_ID="${NEW_API_USER_ID:-$(jq -r '.user_id // empty' "$cfg")}"
    NEW_API_ACCESS_TOKEN="${NEW_API_ACCESS_TOKEN:-$(jq -r '.access_token // empty' "$cfg")}"
    NEW_API_COOKIE_JAR="${NEW_API_COOKIE_JAR:-$(jq -r '.cookie_jar // empty' "$cfg")}"
    NEW_API_TOKEN_KEY="${NEW_API_TOKEN_KEY:-$(jq -r '.token_key // empty' "$cfg")}"
  else
    err "jq is required to load NEW_API_CONFIG"
    return 1
  fi
}

require_jq() {
  if ! command -v jq >/dev/null 2>&1; then
    err "jq is required for this command"
    return 1
  fi
}

urlencode() {
  require_jq
  jq -rn --arg v "$1" '$v|@uri'
}

confirm_or_die() {
  local yes="$1"
  local what="$2"
  if [[ "$yes" != "true" && "$yes" != "1" ]]; then
    err "refusing to proceed without --yes: $what"
    return 1
  fi
}

write_secret() {
  local out="$1"
  local value="$2"
  umask 077
  mkdir -p "$(dirname "$out")"
  printf '%s' "$value" >"$out"
}

curl_base_args() {
  local -a args
  args=(-sS)
  if [[ "${NEW_API_INSECURE:-}" == "true" || "${NEW_API_INSECURE:-}" == "1" ]]; then
    args+=(-k)
  fi
  printf '%s\n' "${args[@]}"
}

require_base_url() {
  if [[ -z "${NEW_API_BASE_URL:-}" ]]; then
    err "missing NEW_API_BASE_URL"
    return 1
  fi
}

require_user_id() {
  if [[ -z "${NEW_API_USER_ID:-}" ]]; then
    err "missing NEW_API_USER_ID (required for any authenticated /api/* request)"
    return 1
  fi
}

call_cmd() {
  local method="${1:-}"
  local path="${2:-}"
  shift 2 || true

  if [[ -z "$method" || -z "$path" ]]; then
    usage
    return 1
  fi

  local auth="auto"
  local output="pretty"
  local json_file=""
  local data_inline=""
  local -a extra_headers=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --auth)
        auth="$2"; shift 2 ;;
      --output)
        output="$2"; shift 2 ;;
      --json)
        json_file="$2"; shift 2 ;;
      --data)
        data_inline="$2"; shift 2 ;;
      --header)
        extra_headers+=("$2"); shift 2 ;;
      -h|--help)
        usage; return 0 ;;
      *)
        err "unknown arg: $1"
        return 1
        ;;
    esac
  done

  require_base_url

  local base
  base="$(trim_trailing_slash "$NEW_API_BASE_URL")"

  # Allow PATH to be either '/api/..' or full url.
  local url="$path"
  if [[ "$url" != http://* && "$url" != https://* ]]; then
    if [[ "$url" != /* ]]; then
      url="/$url"
    fi
    url="$base$url"
  fi

  local use_token=false
  local use_session=false
  local use_sk=false
  case "$auth" in
    token)
      use_token=true
      ;;
    session)
      use_session=true
      ;;
    sk)
      use_sk=true
      ;;
    none)
      # force no auth
      :
      ;;
    auto)
      if [[ -n "${NEW_API_ACCESS_TOKEN:-}" ]]; then
        use_token=true
      elif [[ -n "${NEW_API_COOKIE_JAR:-}" ]]; then
        use_session=true
      else
        # no auth
        :
      fi
      ;;
    *)
      err "invalid --auth: $auth (expected token|session|sk|auto|none)"
      return 1
      ;;
  esac

  local -a curl_args
  mapfile -t curl_args < <(curl_base_args)
  curl_args+=("-X" "$method")

  # headers
  local -a headers
  headers=()
  if $use_token; then
    require_user_id
    if [[ -z "${NEW_API_ACCESS_TOKEN:-}" ]]; then
      err "missing NEW_API_ACCESS_TOKEN"
      return 1
    fi
    headers+=("Authorization: Bearer ${NEW_API_ACCESS_TOKEN}")
    headers+=("New-Api-User: ${NEW_API_USER_ID}")
  elif $use_sk; then
    if [[ -z "${NEW_API_TOKEN_KEY:-}" ]]; then
      err "missing NEW_API_TOKEN_KEY (required for --auth sk)"
      return 1
    fi
    headers+=("Authorization: Bearer ${NEW_API_TOKEN_KEY}")
  elif $use_session; then
    require_user_id
    if [[ -z "${NEW_API_COOKIE_JAR:-}" ]]; then
      err "missing NEW_API_COOKIE_JAR"
      return 1
    fi
    headers+=("New-Api-User: ${NEW_API_USER_ID}")
    curl_args+=("-b" "${NEW_API_COOKIE_JAR}" "-c" "${NEW_API_COOKIE_JAR}")
  else
    # no auth
    if [[ -n "${NEW_API_USER_ID:-}" ]]; then
      headers+=("New-Api-User: ${NEW_API_USER_ID}")
    fi
  fi

  for h in "${extra_headers[@]}"; do
    headers+=("$h")
  done

  for h in "${headers[@]}"; do
    curl_args+=("-H" "$h")
  done

  # body
  if [[ -n "$json_file" && -n "$data_inline" ]]; then
    err "--json and --data are mutually exclusive"
    return 1
  fi
  if [[ -n "$json_file" ]]; then
    if [[ ! -f "$json_file" ]]; then
      err "json file not found: $json_file"
      return 1
    fi
    curl_args+=("-H" "Content-Type: application/json" "--data-binary" "@${json_file}")
  elif [[ -n "$data_inline" ]]; then
    curl_args+=("-H" "Content-Type: application/json" "--data-binary" "$data_inline")
  fi

  # execute
  if [[ "$output" == "raw" ]]; then
    curl "${curl_args[@]}" "$url"
    return 0
  fi
  if command -v jq >/dev/null 2>&1; then
    # Best-effort pretty print. If it's not JSON, fall back to raw.
    local out
    out="$(curl "${curl_args[@]}" "$url" || true)"
    if echo "$out" | jq . >/dev/null 2>&1; then
      echo "$out" | jq .
    else
      echo "$out"
    fi
  else
    curl "${curl_args[@]}" "$url"
  fi
}

doctor_probe() {
  local label="$1"
  local method="$2"
  local path="$3"
  local auth="$4"
  local severity="${5:-hard}"

  require_jq

  local resp=""
  local stderr_file=""
  stderr_file="$(mktemp)"

  local status="pass"
  local success="unknown"
  local message=""
  local data_type=""

  if ! resp="$(call_cmd "$method" "$path" --auth "$auth" --output raw 2>"$stderr_file")"; then
    status="fail"
    success="false"
    message="$(tr '\n' ' ' <"$stderr_file" | sed 's/[[:space:]]\+/ /g; s/^ //; s/ $//')"
  elif echo "$resp" | jq . >/dev/null 2>&1; then
    success="$(echo "$resp" | jq -r 'if has("success") then (.success|tostring) else "unknown" end')"
    message="$(echo "$resp" | jq -r '.message // ""')"
    data_type="$(echo "$resp" | jq -r 'if has("data") then (.data|type) else "" end')"
    if [[ "$success" == "false" ]]; then
      if [[ "$severity" == "soft" ]]; then
        status="soft_fail"
      else
        status="fail"
      fi
    fi
  else
    status="fail"
    success="false"
    message="non-JSON response"
    data_type="text"
  fi

  rm -f "$stderr_file"

  jq -nc \
    --arg name "$label" \
    --arg method "$method" \
    --arg path "$path" \
    --arg auth "$auth" \
    --arg severity "$severity" \
    --arg status "$status" \
    --arg success "$success" \
    --arg message "$message" \
    --arg data_type "$data_type" \
    '{
      name: $name,
      method: $method,
      path: $path,
      auth: $auth,
      severity: $severity,
      status: $status,
      success: $success,
      message: $message,
      data_type: $data_type
    }'
}

doctor_render_summary() {
  local checks_file="$1"
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    local name status severity message icon
    name="$(echo "$line" | jq -r '.name')"
    status="$(echo "$line" | jq -r '.status')"
    severity="$(echo "$line" | jq -r '.severity')"
    message="$(echo "$line" | jq -r '.message // ""')"
    case "$status" in
      pass) icon="PASS" ;;
      soft_fail) icon="SOFT" ;;
      skip) icon="SKIP" ;;
      *) icon="FAIL" ;;
    esac
    if [[ -n "$message" ]]; then
      printf '[doctor] %-4s %-24s %s (%s)\n' "$icon" "$name" "$message" "$severity"
    else
      printf '[doctor] %-4s %-24s (%s)\n' "$icon" "$name" "$severity"
    fi
  done <"$checks_file"
}

doctor_cmd() {
  require_base_url

  local deep="false"
  local json_summary="false"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --deep) deep="true"; shift ;;
      --json) json_summary="true"; shift ;;
      -h|--help)
        usage; return 0 ;;
      *)
        err "unknown arg: $1"
        return 1
        ;;
    esac
  done

  local base auth_mode auth_for_checks
  base="$(trim_trailing_slash "$NEW_API_BASE_URL")"
  auth_mode="none"
  auth_for_checks=""
  if [[ -n "${NEW_API_ACCESS_TOKEN:-}" && -n "${NEW_API_USER_ID:-}" ]]; then
    auth_mode="token"
    auth_for_checks="token"
  elif [[ -n "${NEW_API_COOKIE_JAR:-}" && -n "${NEW_API_USER_ID:-}" ]]; then
    auth_mode="session"
    auth_for_checks="session"
  fi

  if [[ "$deep" != "true" && "$json_summary" != "true" ]]; then
    echo "[doctor] base_url=$base" >&2
    echo "[doctor] user_id=${NEW_API_USER_ID:-<unset>}" >&2
    case "$auth_mode" in
      token)
        echo "[doctor] auth=access_token (Authorization: Bearer …)" >&2 ;;
      session)
        echo "[doctor] auth=session_cookie (cookie jar: ${NEW_API_COOKIE_JAR})" >&2 ;;
      *)
        echo "[doctor] auth=none" >&2 ;;
    esac

    echo "[doctor] GET /api/status" >&2
    call_cmd GET /api/status --auth none

    if [[ -n "$auth_for_checks" ]]; then
      echo "[doctor] GET /api/user/self ($auth_for_checks)" >&2
      call_cmd GET /api/user/self --auth "$auth_for_checks"
    fi
    return 0
  fi

  require_jq

  local checks_file
  checks_file="$(mktemp)"
  doctor_probe "status" GET "/api/status" none hard >>"$checks_file"

  local role=0
  if [[ -n "$auth_for_checks" ]]; then
    doctor_probe "user-self" GET "/api/user/self" "$auth_for_checks" hard >>"$checks_file"
    local self_resp=""
    if self_resp="$(call_cmd GET /api/user/self --auth "$auth_for_checks" --output raw 2>/dev/null)"; then
      role="$(echo "$self_resp" | jq -r '.data.role // 0')"
      [[ "$role" == "null" || -z "$role" ]] && role=0
    fi
  fi

  if [[ "$deep" == "true" ]]; then
    if [[ -n "$auth_for_checks" ]]; then
      if (( role >= 1 )); then
        doctor_probe "subscription-plans" GET "/api/subscription/plans" "$auth_for_checks" hard >>"$checks_file"
        doctor_probe "subscription-self" GET "/api/subscription/self" "$auth_for_checks" hard >>"$checks_file"
        doctor_probe "data-self" GET "/api/data/self" "$auth_for_checks" hard >>"$checks_file"
        doctor_probe "task-self" GET "/api/task/self" "$auth_for_checks" hard >>"$checks_file"
      fi

      if (( role >= 10 )); then
        doctor_probe "channel-list" GET "/api/channel/?p=1&page_size=1" "$auth_for_checks" hard >>"$checks_file"
        doctor_probe "token-list" GET "/api/token/?p=1&page_size=1" "$auth_for_checks" hard >>"$checks_file"
        doctor_probe "models-list" GET "/api/models/?p=1&page_size=1" "$auth_for_checks" hard >>"$checks_file"
        doctor_probe "vendors-list" GET "/api/vendors/?p=1&page_size=1" "$auth_for_checks" hard >>"$checks_file"
        doctor_probe "group-list" GET "/api/group/" "$auth_for_checks" hard >>"$checks_file"
        doctor_probe "prefill-group-list" GET "/api/prefill_group/" "$auth_for_checks" hard >>"$checks_file"
        doctor_probe "redemption-list" GET "/api/redemption/?p=1&page_size=1" "$auth_for_checks" hard >>"$checks_file"
        doctor_probe "performance-stats" GET "/api/performance/stats" "$auth_for_checks" hard >>"$checks_file"
      fi

      if (( role >= 100 )); then
        doctor_probe "option-get" GET "/api/option/" "$auth_for_checks" hard >>"$checks_file"
        doctor_probe "subscription-admin-plans" GET "/api/subscription/admin/plans" "$auth_for_checks" hard >>"$checks_file"
        doctor_probe "deployments-settings" GET "/api/deployments/settings" "$auth_for_checks" soft >>"$checks_file"
      fi
    fi
  fi

  if [[ "$json_summary" == "true" ]]; then
    jq -s \
      --arg base_url "$base" \
      --arg auth_mode "$auth_mode" \
      --arg user_id "${NEW_API_USER_ID:-}" \
      --argjson role "$role" \
      '{
        base_url: $base_url,
        auth_mode: $auth_mode,
        user_id: (if $user_id == "" then null else $user_id end),
        role: $role,
        summary: {
          total: length,
          pass: ([.[] | select(.status == "pass")] | length),
          soft_fail: ([.[] | select(.status == "soft_fail")] | length),
          fail: ([.[] | select(.status == "fail")] | length)
        },
        checks: .
      }' "$checks_file"
  else
    echo "[doctor] base_url=$base" >&2
    echo "[doctor] user_id=${NEW_API_USER_ID:-<unset>} role=$role auth=$auth_mode" >&2
    if [[ -z "$auth_for_checks" ]]; then
      echo "[doctor] authenticated checks skipped: set NEW_API_USER_ID + NEW_API_ACCESS_TOKEN or NEW_API_COOKIE_JAR" >&2
    fi
    doctor_render_summary "$checks_file" >&2
  fi

  local fail_count
  fail_count="$(jq -s '[.[] | select(.status == "fail")] | length' "$checks_file")"
  rm -f "$checks_file"
  [[ "$fail_count" == "0" ]]
}

routes_cmd() {
  local sub="${1:-}"
  shift || true
  case "$sub" in
    gen|generate|show|list|"" )
      :
      ;;
    *)
      err "routes subcommand: $sub (expected gen)"
      return 1
      ;;
  esac

  local code_dir="${NEW_API_CODE_DIR:-}"
  local router_file=""
  local format="md"
  local out=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --code-dir)
        code_dir="$2"; shift 2 ;;
      --router-file)
        router_file="$2"; shift 2 ;;
      --format)
        format="$2"; shift 2 ;;
      --out)
        out="$2"; shift 2 ;;
      -h|--help)
        usage; return 0 ;;
      *)
        err "unknown arg: $1"
        return 1
        ;;
    esac
  done

  local script_dir
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  local gen="$script_dir/generate_routes.py"

  local -a py_args
  py_args=("$gen" "--format" "$format")
  if [[ -n "$code_dir" ]]; then
    py_args+=("--code-dir" "$code_dir")
  fi
  if [[ -n "$router_file" ]]; then
    py_args+=("--router-file" "$router_file")
  fi
  if [[ -n "$out" ]]; then
    py_args+=("--out" "$out")
  fi

  python3 "${py_args[@]}"
}

channel_list_cmd() {
  local p=1
  local page_size=20
  local status="all"
  local type=""
  local id_sort="false"
  local tag_mode="false"
  local auth="token"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --p) p="$2"; shift 2 ;;
      --page-size) page_size="$2"; shift 2 ;;
      --status) status="$2"; shift 2 ;;
      --type) type="$2"; shift 2 ;;
      --id-sort) id_sort="true"; shift ;;
      --tag-mode) tag_mode="true"; shift ;;
      --auth) auth="$2"; shift 2 ;;
      -h|--help)
        usage; return 0 ;;
      *)
        err "unknown arg: $1"
        return 1
        ;;
    esac
  done

  local qs="p=$p&page_size=$page_size&id_sort=$id_sort&tag_mode=$tag_mode"
  if [[ "$status" != "all" ]]; then
    qs="$qs&status=$(urlencode "$status")"
  fi
  if [[ -n "$type" ]]; then
    qs="$qs&type=$(urlencode "$type")"
  fi

  call_cmd GET "/api/channel/?$qs" --auth "$auth"
}

channel_search_cmd() {
  local keyword=""
  local group=""
  local model_kw=""
  local p=1
  local page_size=20
  local status="all"
  local type=""
  local id_sort="false"
  local tag_mode="false"
  local auth="token"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --keyword) keyword="$2"; shift 2 ;;
      --group) group="$2"; shift 2 ;;
      --model) model_kw="$2"; shift 2 ;;
      --p) p="$2"; shift 2 ;;
      --page-size) page_size="$2"; shift 2 ;;
      --status) status="$2"; shift 2 ;;
      --type) type="$2"; shift 2 ;;
      --id-sort) id_sort="true"; shift ;;
      --tag-mode) tag_mode="true"; shift ;;
      --auth) auth="$2"; shift 2 ;;
      -h|--help)
        usage; return 0 ;;
      *)
        err "unknown arg: $1"
        return 1
        ;;
    esac
  done
  if [[ -z "$keyword" ]]; then
    err "channel search requires --keyword"
    return 1
  fi

  local qs="keyword=$(urlencode "$keyword")&p=$p&page_size=$page_size&id_sort=$id_sort&tag_mode=$tag_mode"
  if [[ -n "$group" ]]; then
    qs="$qs&group=$(urlencode "$group")"
  fi
  if [[ -n "$model_kw" ]]; then
    qs="$qs&model=$(urlencode "$model_kw")"
  fi
  if [[ "$status" != "all" ]]; then
    qs="$qs&status=$(urlencode "$status")"
  fi
  if [[ -n "$type" ]]; then
    qs="$qs&type=$(urlencode "$type")"
  fi

  call_cmd GET "/api/channel/search?$qs" --auth "$auth"
}

channel_get_cmd() {
  local id=""
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --id) id="$2"; shift 2 ;;
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
    esac
  done
  if [[ -z "$id" ]]; then
    err "channel get requires --id"
    return 1
  fi
  call_cmd GET "/api/channel/$id" --auth "$auth"
}

