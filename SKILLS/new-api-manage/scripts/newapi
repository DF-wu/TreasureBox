log_list_cmd() {
  local p=1 page_size=20
  local type="" start_ts="" end_ts="" username="" token_name="" model_name="" channel="" group="" request_id=""
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --p) p="$2"; shift 2 ;;
      --page-size) page_size="$2"; shift 2 ;;
      --type) type="$2"; shift 2 ;;
      --start) start_ts="$2"; shift 2 ;;
      --end) end_ts="$2"; shift 2 ;;
      --username) username="$2"; shift 2 ;;
      --token-name) token_name="$2"; shift 2 ;;
      --model-name) model_name="$2"; shift 2 ;;
      --channel) channel="$2"; shift 2 ;;
      --group) group="$2"; shift 2 ;;
      --request-id) request_id="$2"; shift 2 ;;
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
    esac
  done
  local qs="p=$p&page_size=$page_size"
  [[ -n "$type" ]] && qs="$qs&type=$(urlencode "$type")"
  [[ -n "$start_ts" ]] && qs="$qs&start_timestamp=$(urlencode "$start_ts")"
  [[ -n "$end_ts" ]] && qs="$qs&end_timestamp=$(urlencode "$end_ts")"
  [[ -n "$username" ]] && qs="$qs&username=$(urlencode "$username")"
  [[ -n "$token_name" ]] && qs="$qs&token_name=$(urlencode "$token_name")"
  [[ -n "$model_name" ]] && qs="$qs&model_name=$(urlencode "$model_name")"
  [[ -n "$channel" ]] && qs="$qs&channel=$(urlencode "$channel")"
  [[ -n "$group" ]] && qs="$qs&group=$(urlencode "$group")"
  [[ -n "$request_id" ]] && qs="$qs&request_id=$(urlencode "$request_id")"
  call_cmd GET "/api/log/?$qs" --auth "$auth"
}

log_stat_cmd() {
  local type="" start_ts="" end_ts="" username="" token_name="" model_name="" channel="" group=""
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --type) type="$2"; shift 2 ;;
      --start) start_ts="$2"; shift 2 ;;
      --end) end_ts="$2"; shift 2 ;;
      --username) username="$2"; shift 2 ;;
      --token-name) token_name="$2"; shift 2 ;;
      --model-name) model_name="$2"; shift 2 ;;
      --channel) channel="$2"; shift 2 ;;
      --group) group="$2"; shift 2 ;;
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
    esac
  done
  local qs=""
  [[ -n "$type" ]] && qs="${qs}type=$(urlencode "$type")"
  [[ -n "$start_ts" ]] && qs="${qs:+$qs&}start_timestamp=$(urlencode "$start_ts")"
  [[ -n "$end_ts" ]] && qs="${qs:+$qs&}end_timestamp=$(urlencode "$end_ts")"
  [[ -n "$username" ]] && qs="${qs:+$qs&}username=$(urlencode "$username")"
  [[ -n "$token_name" ]] && qs="${qs:+$qs&}token_name=$(urlencode "$token_name")"
  [[ -n "$model_name" ]] && qs="${qs:+$qs&}model_name=$(urlencode "$model_name")"
  [[ -n "$channel" ]] && qs="${qs:+$qs&}channel=$(urlencode "$channel")"
  [[ -n "$group" ]] && qs="${qs:+$qs&}group=$(urlencode "$group")"
  local path="/api/log/stat"
  [[ -n "$qs" ]] && path="$path?$qs"
  call_cmd GET "$path" --auth "$auth"
}

