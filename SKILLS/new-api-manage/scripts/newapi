subscription_admin_plans_create_cmd() {
  local json_file=""
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json) json_file="$2"; shift 2 ;;
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
    esac
  done
  [[ -z "$json_file" ]] && { err "subscription admin plans create requires --json"; return 1; }
  call_cmd POST "/api/subscription/admin/plans" --auth "$auth" --json "$json_file"
}

subscription_admin_plans_update_cmd() {
  local id=""
  local json_file=""
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --id) id="$2"; shift 2 ;;
      --json) json_file="$2"; shift 2 ;;
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
    esac
  done
  [[ -z "$id" || -z "$json_file" ]] && { err "subscription admin plans update requires --id and --json"; return 1; }
  call_cmd PUT "/api/subscription/admin/plans/$id" --auth "$auth" --json "$json_file"
}

subscription_admin_plans_set_enabled_cmd() {
  require_jq
  local id=""
  local enabled=""
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --id) id="$2"; shift 2 ;;
      --enabled) enabled="$2"; shift 2 ;;
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
    esac
  done
  [[ -z "$id" || -z "$enabled" ]] && { err "subscription admin plans set-enabled requires --id and --enabled"; return 1; }
  local body
  body="$(jq -nc --arg enabled "$enabled" '{enabled: ($enabled|ascii_downcase=="true")}')"
  call_cmd PATCH "/api/subscription/admin/plans/$id" --auth "$auth" --data "$body"
}

subscription_admin_bind_cmd() {
  require_jq
  local user_id="" plan_id=""
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --user-id) user_id="$2"; shift 2 ;;
      --plan-id) plan_id="$2"; shift 2 ;;
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
    esac
  done
  [[ -z "$user_id" || -z "$plan_id" ]] && { err "subscription admin bind requires --user-id and --plan-id"; return 1; }
  local body
  body="$(jq -nc --arg uid "$user_id" --arg pid "$plan_id" '{user_id: ($uid|tonumber), plan_id: ($pid|tonumber)}')"
  call_cmd POST "/api/subscription/admin/bind" --auth "$auth" --data "$body"
}

subscription_admin_user_subscriptions_list_cmd() {
  local user_id=""
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --user-id) user_id="$2"; shift 2 ;;
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
    esac
  done
  [[ -z "$user_id" ]] && { err "subscription admin user-subscriptions list requires --user-id"; return 1; }
  call_cmd GET "/api/subscription/admin/users/$user_id/subscriptions" --auth "$auth"
}

subscription_admin_user_subscriptions_create_cmd() {
  require_jq
  local user_id="" plan_id=""
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --user-id) user_id="$2"; shift 2 ;;
      --plan-id) plan_id="$2"; shift 2 ;;
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
    esac
  done
  [[ -z "$user_id" || -z "$plan_id" ]] && { err "subscription admin user-subscriptions create requires --user-id and --plan-id"; return 1; }
  local body
  body="$(jq -nc --arg pid "$plan_id" '{plan_id: ($pid|tonumber)}')"
  call_cmd POST "/api/subscription/admin/users/$user_id/subscriptions" --auth "$auth" --data "$body"
}

subscription_admin_user_subscription_invalidate_cmd() {
  local sub_id=""
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --id) sub_id="$2"; shift 2 ;;
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
    esac
  done
  [[ -z "$sub_id" ]] && { err "subscription admin user-subscription invalidate requires --id"; return 1; }
  call_cmd POST "/api/subscription/admin/user_subscriptions/$sub_id/invalidate" --auth "$auth"
}

subscription_admin_user_subscription_delete_cmd() {
  local sub_id=""
  local yes="false"
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --id) sub_id="$2"; shift 2 ;;
      --yes) yes="true"; shift ;;
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
    esac
  done
  [[ -z "$sub_id" ]] && { err "subscription admin user-subscription delete requires --id"; return 1; }
  confirm_or_die "$yes" "DELETE /api/subscription/admin/user_subscriptions/$sub_id"
  call_cmd DELETE "/api/subscription/admin/user_subscriptions/$sub_id" --auth "$auth"
}

subscription_cmd() {
  local sub="${1:-}"
  shift || true
  case "$sub" in
    plans) subscription_plans_cmd "$@" ;;
    self) subscription_self_cmd "$@" ;;
    preference) subscription_preference_cmd "$@" ;;
    admin)
      local sub2="${1:-}"
      shift || true
      case "$sub2" in
        plans)
          local sub3="${1:-}"
          shift || true
          case "$sub3" in
            list) subscription_admin_plans_list_cmd "$@" ;;
            create) subscription_admin_plans_create_cmd "$@" ;;
            update) subscription_admin_plans_update_cmd "$@" ;;
            set-enabled) subscription_admin_plans_set_enabled_cmd "$@" ;;
            *) err "subscription admin plans expects: list|create|update|set-enabled"; return 1 ;;
          esac
          ;;
        bind) subscription_admin_bind_cmd "$@" ;;
        user-subscriptions)
          local sub3="${1:-}"
          shift || true
          case "$sub3" in
            list) subscription_admin_user_subscriptions_list_cmd "$@" ;;
            create) subscription_admin_user_subscriptions_create_cmd "$@" ;;
            invalidate) subscription_admin_user_subscription_invalidate_cmd "$@" ;;
            delete) subscription_admin_user_subscription_delete_cmd "$@" ;;
            *) err "subscription admin user-subscriptions expects: list|create|invalidate|delete"; return 1 ;;
          esac
          ;;
        *) err "subscription admin expects: plans|bind|user-subscriptions"; return 1 ;;
      esac
      ;;
    *) err "subscription expects: plans|self|preference|admin"; return 1 ;;
  esac
}

deployments_settings_cmd() {
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
    esac
  done
  call_cmd GET "/api/deployments/settings" --auth "$auth"
}

deployments_list_cmd() {
  local p=1 page_size=20 status=""
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --p) p="$2"; shift 2 ;;
      --page-size) page_size="$2"; shift 2 ;;
      --status) status="$2"; shift 2 ;;
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
    esac
  done
  local qs="p=$p&page_size=$page_size"
  [[ -n "$status" ]] && qs="$qs&status=$(urlencode "$status")"
  call_cmd GET "/api/deployments/?$qs" --auth "$auth"
}

deployments_search_cmd() {
  local p=1 page_size=20 status="" keyword=""
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --p) p="$2"; shift 2 ;;
      --page-size) page_size="$2"; shift 2 ;;
      --status) status="$2"; shift 2 ;;
      --keyword) keyword="$2"; shift 2 ;;
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
    esac
  done
  local qs="p=$p&page_size=$page_size"
  [[ -n "$status" ]] && qs="$qs&status=$(urlencode "$status")"
  [[ -n "$keyword" ]] && qs="$qs&keyword=$(urlencode "$keyword")"
  call_cmd GET "/api/deployments/search?$qs" --auth "$auth"
}

