    search) deployments_search_cmd "$@" ;;
    get) deployments_get_cmd "$@" ;;
    create) deployments_create_cmd "$@" ;;
    update) deployments_update_cmd "$@" ;;
    update-name) deployments_update_name_cmd "$@" ;;
