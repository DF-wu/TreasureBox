deployments_logs_cmd() {
  local id="" container_id="" limit="" cursor="" follow="" level="" stream="" start_time="" end_time=""
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --id) id="$2"; shift 2 ;;
      --container-id) container_id="$2"; shift 2 ;;
      --limit) limit="$2"; shift 2 ;;
      --cursor) cursor="$2"; shift 2 ;;
      --follow) follow="$2"; shift 2 ;;
      --level) level="$2"; shift 2 ;;
      --stream) stream="$2"; shift 2 ;;
      --start-time) start_time="$2"; shift 2 ;;
      --end-time) end_time="$2"; shift 2 ;;
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
    esac
  done
  [[ -z "$id" || -z "$container_id" ]] && { err "deployments logs requires --id and --container-id"; return 1; }
  local qs="container_id=$(urlencode "$container_id")"
  [[ -n "$limit" ]] && qs="$qs&limit=$(urlencode "$limit")"
  [[ -n "$cursor" ]] && qs="$qs&cursor=$(urlencode "$cursor")"
  [[ -n "$follow" ]] && qs="$qs&follow=$(urlencode "$follow")"
  [[ -n "$level" ]] && qs="$qs&level=$(urlencode "$level")"
  [[ -n "$stream" ]] && qs="$qs&stream=$(urlencode "$stream")"
  [[ -n "$start_time" ]] && qs="$qs&start_time=$(urlencode "$start_time")"
  [[ -n "$end_time" ]] && qs="$qs&end_time=$(urlencode "$end_time")"
  call_cmd GET "/api/deployments/$id/logs?$qs" --auth "$auth"
}

