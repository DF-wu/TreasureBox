channel_batch_delete_cmd() {
  require_jq
  local ids=""
  local yes="false"
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --ids) ids="$2"; shift 2 ;;
      --yes) yes="true"; shift ;;
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
    esac
  done
  if [[ -z "$ids" ]]; then
    err "channel batch-delete requires --ids '1,2,3'"
    return 1
  fi
  confirm_or_die "$yes" "POST /api/channel/batch ids=$ids"
  local body
  body="$(jq -nc --arg ids "$ids" '{ids: ($ids|split(",")|map(tonumber))}')"
  call_cmd POST "/api/channel/batch" --auth "$auth" --data "$body"
}

channel_batch_tag_cmd() {
  require_jq
  local ids=""
  local tag=""
  local yes="false"
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --ids) ids="$2"; shift 2 ;;
      --tag) tag="$2"; shift 2 ;;
      --yes) yes="true"; shift ;;
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
    esac
  done
  if [[ -z "$ids" || -z "$tag" ]]; then
    err "channel batch-tag requires --ids and --tag"
    return 1
  fi
  confirm_or_die "$yes" "POST /api/channel/batch/tag ids=$ids tag=$tag"
  local body
  body="$(jq -nc --arg ids "$ids" --arg tag "$tag" '{ids: ($ids|split(",")|map(tonumber)), tag: $tag}')"
  call_cmd POST "/api/channel/batch/tag" --auth "$auth" --data "$body"
}

channel_copy_cmd() {
  local id=""
  local suffix=""
  local reset_balance=""
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --id) id="$2"; shift 2 ;;
      --suffix) suffix="$2"; shift 2 ;;
      --reset-balance) reset_balance="$2"; shift 2 ;;
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
    esac
  done
  if [[ -z "$id" ]]; then
    err "channel copy requires --id"
    return 1
  fi
  local qs=""
  if [[ -n "$suffix" ]]; then
    qs="suffix=$(urlencode "$suffix")"
  fi
  if [[ -n "$reset_balance" ]]; then
    if [[ -n "$qs" ]]; then qs="$qs&"; fi
    qs="${qs}reset_balance=$(urlencode "$reset_balance")"
  fi
  local path="/api/channel/copy/$id"
  if [[ -n "$qs" ]]; then
    path="$path?$qs"
  fi
  call_cmd POST "$path" --auth "$auth"
}

channel_upstream_updates_cmd() {
  require_jq
  local sub="${1:-}"
  shift || true
  local auth="token"

  case "$sub" in
    detect)
      local id=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --id) id="$2"; shift 2 ;;
          --auth) auth="$2"; shift 2 ;;
          *) err "unknown arg: $1"; return 1 ;;
        esac
      done
      if [[ -z "$id" ]]; then err "detect requires --id"; return 1; fi
      call_cmd POST "/api/channel/upstream_updates/detect" --auth "$auth" --data "$(jq -nc --arg id "$id" '{id: ($id|tonumber)}')"
      ;;
    apply)
      local id=""
      local add=""
      local remove=""
      local ignore=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --id) id="$2"; shift 2 ;;
          --add) add="$2"; shift 2 ;;
          --remove) remove="$2"; shift 2 ;;
          --ignore) ignore="$2"; shift 2 ;;
          --auth) auth="$2"; shift 2 ;;
          *) err "unknown arg: $1"; return 1 ;;
        esac
      done
      if [[ -z "$id" ]]; then err "apply requires --id"; return 1; fi
      local body
      body="$(jq -nc --arg id "$id" --arg add "$add" --arg remove "$remove" --arg ignore "$ignore" '
        def to_arr($s): ($s|split(",")|map(gsub("^\\s+|\\s+$";""))|map(select(length>0)));
        {id: ($id|tonumber), add_models: to_arr($add), remove_models: to_arr($remove), ignore_models: to_arr($ignore)}
      ')"
      call_cmd POST "/api/channel/upstream_updates/apply" --auth "$auth" --data "$body"
      ;;
    detect-all)
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --auth) auth="$2"; shift 2 ;;
          *) err "unknown arg: $1"; return 1 ;;
        esac
      done
      call_cmd POST "/api/channel/upstream_updates/detect_all" --auth "$auth"
      ;;
    apply-all)
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --auth) auth="$2"; shift 2 ;;
          *) err "unknown arg: $1"; return 1 ;;
        esac
      done
      call_cmd POST "/api/channel/upstream_updates/apply_all" --auth "$auth"
      ;;
    *)
      err "upstream-updates expects: detect|apply|detect-all|apply-all"
      return 1
      ;;
  esac
}

channel_cmd() {
  local sub="${1:-}"
  shift || true
  case "$sub" in
    list) channel_list_cmd "$@" ;;
    search) channel_search_cmd "$@" ;;
    get) channel_get_cmd "$@" ;;
    create) channel_create_cmd "$@" ;;
    update) channel_update_cmd "$@" ;;
    delete) channel_delete_cmd "$@" ;;
    batch-delete) channel_batch_delete_cmd "$@" ;;
    batch-tag) channel_batch_tag_cmd "$@" ;;
    copy) channel_copy_cmd "$@" ;;
    upstream-updates) channel_upstream_updates_cmd "$@" ;;
    *)
      err "unknown channel subcommand: $sub"
      return 1
      ;;
  esac
}

token_list_cmd() {
  local p=1
  local page_size=20
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --p) p="$2"; shift 2 ;;
      --page-size) page_size="$2"; shift 2 ;;
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
    esac
  done
  call_cmd GET "/api/token/?p=$p&page_size=$page_size" --auth "$auth"
}

token_search_cmd() {
  local keyword=""
  local token_part=""
  local p=1
  local page_size=20
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --keyword) keyword="$2"; shift 2 ;;
      --token) token_part="$2"; shift 2 ;;
      --p) p="$2"; shift 2 ;;
      --page-size) page_size="$2"; shift 2 ;;
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
    esac
  done
  local qs="p=$p&page_size=$page_size"
  if [[ -n "$keyword" ]]; then qs="$qs&keyword=$(urlencode "$keyword")"; fi
  if [[ -n "$token_part" ]]; then qs="$qs&token=$(urlencode "$token_part")"; fi
  call_cmd GET "/api/token/search?$qs" --auth "$auth"
}

token_get_cmd() {
  local id=""
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --id) id="$2"; shift 2 ;;
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
    esac
  done
  if [[ -z "$id" ]]; then err "token get requires --id"; return 1; fi
  call_cmd GET "/api/token/$id" --auth "$auth"
}

