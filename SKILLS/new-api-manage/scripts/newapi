log_delete_history_cmd() {
  local target_ts=""
  local yes="false"
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --target-timestamp) target_ts="$2"; shift 2 ;;
      --yes) yes="true"; shift ;;
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
    esac
  done
  if [[ -z "$target_ts" ]]; then err "log delete-history requires --target-timestamp"; return 1; fi
  confirm_or_die "$yes" "DELETE /api/log/?target_timestamp=$target_ts"
  call_cmd DELETE "/api/log/?target_timestamp=$(urlencode "$target_ts")" --auth "$auth"
}

log_channel_affinity_usage_cache_cmd() {
  local rule_name="" key_fp="" using_group=""
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --rule-name) rule_name="$2"; shift 2 ;;
      --key-fp) key_fp="$2"; shift 2 ;;
      --using-group) using_group="$2"; shift 2 ;;
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
    esac
  done
  if [[ -z "$rule_name" || -z "$key_fp" ]]; then
    err "log channel-affinity-usage-cache requires --rule-name and --key-fp"
    return 1
  fi
  local qs=""
  [[ -n "$rule_name" ]] && qs="${qs}rule_name=$(urlencode "$rule_name")"
  [[ -n "$key_fp" ]] && qs="${qs:+$qs&}key_fp=$(urlencode "$key_fp")"
  [[ -n "$using_group" ]] && qs="${qs:+$qs&}using_group=$(urlencode "$using_group")"
  local path="/api/log/channel_affinity_usage_cache"
  [[ -n "$qs" ]] && path="$path?$qs"
  call_cmd GET "$path" --auth "$auth"
}

log_cmd() {
  local sub="${1:-}"
  shift || true
  case "$sub" in
    list) log_list_cmd "$@" ;;
    stat) log_stat_cmd "$@" ;;
    self) log_self_cmd "$@" ;;
    self-stat) log_self_stat_cmd "$@" ;;
    token) log_token_cmd "$@" ;;
    delete-history) log_delete_history_cmd "$@" ;;
    channel-affinity-usage-cache) log_channel_affinity_usage_cache_cmd "$@" ;;
    *) err "log expects: list|stat|self|self-stat|token|delete-history|channel-affinity-usage-cache"; return 1 ;;
  esac
}

