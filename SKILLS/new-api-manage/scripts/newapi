redemption_get_cmd() {
  local id=""
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --id) id="$2"; shift 2 ;;
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
