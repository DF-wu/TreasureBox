    delete) deployments_delete_cmd "$@" ;;
    logs) deployments_logs_cmd "$@" ;;
    containers) deployments_containers_cmd "$@" ;;
    container) deployments_container_cmd "$@" ;;
    hardware-types) deployments_hardware_types_cmd "$@" ;;
