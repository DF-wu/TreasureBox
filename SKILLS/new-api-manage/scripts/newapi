option_get_cmd() {
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
    esac
  done
  call_cmd GET "/api/option/" --auth "$auth"
}

option_set_cmd() {
  require_jq
  local key=""
  local value=""
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --key) key="$2"; shift 2 ;;
      --value) value="$2"; shift 2 ;;
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
    esac
  done
  if [[ -z "$key" ]]; then err "option set requires --key"; return 1; fi

  local body
  body="$(jq -nc --arg k "$key" --arg v "$value" '
    def parse($s):
      if ($s|ascii_downcase) == "true" then true
      elif ($s|ascii_downcase) == "false" then false
      elif ($s|test("^-?[0-9]+(\\.[0-9]+)?$")) then ($s|tonumber)
      else $s end;
    {key: $k, value: parse($v)}
  ')"
  call_cmd PUT "/api/option/" --auth "$auth" --data "$body"
}

option_reset_model_ratio_cmd() {
  local yes="false"
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --yes) yes="true"; shift ;;
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
    esac
  done
  confirm_or_die "$yes" "POST /api/option/rest_model_ratio"
  call_cmd POST "/api/option/rest_model_ratio" --auth "$auth"
}

option_affinity_cache_stats_cmd() {
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
    esac
  done
  call_cmd GET "/api/option/channel_affinity_cache" --auth "$auth"
}

option_affinity_cache_clear_cmd() {
  local all="false"
  local rule_name=""
  local yes="false"
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --all) all="true"; shift ;;
      --rule-name) rule_name="$2"; shift 2 ;;
      --yes) yes="true"; shift ;;
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
    esac
  done
  if [[ "$all" != "true" && -z "$rule_name" ]]; then
    err "affinity-cache clear requires --all or --rule-name"
    return 1
  fi
  confirm_or_die "$yes" "DELETE /api/option/channel_affinity_cache"

  local path="/api/option/channel_affinity_cache"
  if [[ "$all" == "true" ]]; then
    path="$path?all=true"
  else
    path="$path?rule_name=$(urlencode "$rule_name")"
  fi
  call_cmd DELETE "$path" --auth "$auth"
}

option_cmd() {
  local sub="${1:-}"
  shift || true
  case "$sub" in
    get) option_get_cmd "$@" ;;
    set) option_set_cmd "$@" ;;
    reset-model-ratio) option_reset_model_ratio_cmd "$@" ;;
    affinity-cache)
      local sub2="${1:-}"
      shift || true
      case "$sub2" in
        stats) option_affinity_cache_stats_cmd "$@" ;;
        clear) option_affinity_cache_clear_cmd "$@" ;;
        *) err "option affinity-cache expects stats|clear"; return 1 ;;
      esac
      ;;
    *) err "unknown option subcommand: $sub"; return 1 ;;
  esac
}

