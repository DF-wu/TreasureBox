models_create_cmd() {
  local json_file=""
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json) json_file="$2"; shift 2 ;;
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
    esac
  done
  if [[ -z "$json_file" ]]; then err "models create requires --json"; return 1; fi
  call_cmd POST "/api/models/" --auth "$auth" --json "$json_file"
}

