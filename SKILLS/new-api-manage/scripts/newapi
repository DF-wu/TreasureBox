token_delete_cmd() {
  local id=""
  local yes="false"
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --id) id="$2"; shift 2 ;;
      --yes) yes="true"; shift ;;
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
    esac
  done
  if [[ -z "$id" ]]; then err "token delete requires --id"; return 1; fi
  confirm_or_die "$yes" "DELETE /api/token/$id"
  call_cmd DELETE "/api/token/$id" --auth "$auth"
}

token_key_cmd() {
  require_jq
  local id=""
  local out=""
  local stdout="false"
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --id) id="$2"; shift 2 ;;
      --out) out="$2"; shift 2 ;;
      --stdout) stdout="true"; shift ;;
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
    esac
  done
  if [[ -z "$id" ]]; then err "token key requires --id"; return 1; fi
  if [[ -z "$out" && "$stdout" != "true" ]]; then
    err "token key is sensitive; use --out <file> (recommended) or --stdout"
    return 1
  fi

  local res
  res="$(call_cmd POST "/api/token/$id/key" --auth "$auth" --output raw)"
  local key
  key="$(echo "$res" | jq -r '.data.key // empty')"
  if [[ -z "$key" ]]; then
    err "failed to extract key from response"
    echo "$res" | (command -v jq >/dev/null 2>&1 && jq . || cat)
    return 1
  fi

  if [[ -n "$out" ]]; then
    write_secret "$out" "$key"
    err "wrote token key to: $out"
  fi
  if [[ "$stdout" == "true" ]]; then
    echo "$key"
  fi
}

token_cmd() {
  local sub="${1:-}"
  shift || true
  case "$sub" in
    list) token_list_cmd "$@" ;;
    search) token_search_cmd "$@" ;;
    get) token_get_cmd "$@" ;;
    create) token_create_cmd "$@" ;;
    update) token_update_cmd "$@" ;;
    delete) token_delete_cmd "$@" ;;
    key) token_key_cmd "$@" ;;
    *)
      err "unknown token subcommand: $sub"
      return 1
      ;;
  esac
}

