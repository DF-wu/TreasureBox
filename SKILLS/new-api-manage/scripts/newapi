  [[ -z "$id" ]] && { err "redemption get requires --id"; return 1; }
  call_cmd GET "/api/redemption/$id" --auth "$auth"
}

redemption_create_cmd() {
  require_jq
  local json_file=""
  local out=""
  local stdout="false"
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json) json_file="$2"; shift 2 ;;
      --out) out="$2"; shift 2 ;;
      --stdout) stdout="true"; shift ;;
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
    esac
  done
  [[ -z "$json_file" ]] && { err "redemption create requires --json"; return 1; }
  if [[ -z "$out" && "$stdout" != "true" ]]; then
    err "redemption keys are sensitive; use --out <file> (recommended) or --stdout"
    return 1
  fi

  local res
  res="$(call_cmd POST "/api/redemption/" --auth "$auth" --json "$json_file" --output raw)"
  local keys
  keys="$(echo "$res" | jq -r '.data[]?')"
  if [[ -z "$keys" ]]; then
    err "failed to extract keys from response"
    echo "$res" | (command -v jq >/dev/null 2>&1 && jq . || cat)
    return 1
  fi
  if [[ -n "$out" ]]; then
    umask 077
    mkdir -p "$(dirname "$out")"
    printf '%s\n' "$keys" >"$out"
    err "wrote redemption keys to: $out"
  fi
  if [[ "$stdout" == "true" ]]; then
    printf '%s\n' "$keys"
  fi
}

redemption_update_cmd() {
  local json_file=""
  local status_only="false"
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json) json_file="$2"; shift 2 ;;
      --status-only) status_only="true"; shift ;;
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
    esac
  done
  [[ -z "$json_file" ]] && { err "redemption update requires --json"; return 1; }
  local path="/api/redemption/"
  if [[ "$status_only" == "true" ]]; then
    path="$path?status_only=true"
  fi
  call_cmd PUT "$path" --auth "$auth" --json "$json_file"
}

redemption_delete_cmd() {
  local id=""
  local yes="false"
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --id) id="$2"; shift 2 ;;
      --yes) yes="true"; shift ;;
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
    esac
  done
  [[ -z "$id" ]] && { err "redemption delete requires --id"; return 1; }
  confirm_or_die "$yes" "DELETE /api/redemption/$id"
  call_cmd DELETE "/api/redemption/$id" --auth "$auth"
}

redemption_delete_invalid_cmd() {
  local yes="false"
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --yes) yes="true"; shift ;;
      --auth) auth="$2"; shift 2 ;;
      *) err "unknown arg: $1"; return 1 ;;
    esac
  done
  confirm_or_die "$yes" "DELETE /api/redemption/invalid"
  call_cmd DELETE "/api/redemption/invalid" --auth "$auth"
}

redemption_cmd() {
  local sub="${1:-}"
  shift || true
  case "$sub" in
    list) redemption_list_cmd "$@" ;;
    search) redemption_search_cmd "$@" ;;
    get) redemption_get_cmd "$@" ;;
    create) redemption_create_cmd "$@" ;;
    update) redemption_update_cmd "$@" ;;
    delete) redemption_delete_cmd "$@" ;;
    delete-invalid) redemption_delete_invalid_cmd "$@" ;;
    *) err "redemption expects: list|search|get|create|update|delete|delete-invalid"; return 1 ;;
  esac
}

performance_cmd() {
  local sub="${1:-}"
  shift || true
  local yes="false"
  local auth="token"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --yes) yes="true"; shift ;;
      --auth) auth="$2"; shift 2 ;;
      *) break ;;
    esac
  done

  case "$sub" in
    stats) call_cmd GET "/api/performance/stats" --auth "$auth" ;;
    clear-disk-cache)
      confirm_or_die "$yes" "DELETE /api/performance/disk_cache"
      call_cmd DELETE "/api/performance/disk_cache" --auth "$auth"
      ;;
    reset-stats)
      confirm_or_die "$yes" "POST /api/performance/reset_stats"
      call_cmd POST "/api/performance/reset_stats" --auth "$auth"
      ;;
    gc)
      confirm_or_die "$yes" "POST /api/performance/gc"
      call_cmd POST "/api/performance/gc" --auth "$auth"
      ;;
    *) err "performance expects: stats|clear-disk-cache|reset-stats|gc"; return 1 ;;
  esac
}

ratio_sync_cmd() {
  local sub="${1:-}"
  shift || true
  local auth="token"
  case "$sub" in
    channels)
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --auth) auth="$2"; shift 2 ;;
          *) err "unknown arg: $1"; return 1 ;;
        esac
      done
      call_cmd GET "/api/ratio_sync/channels" --auth "$auth"
      ;;
    fetch)
      local json_file=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --json) json_file="$2"; shift 2 ;;
          --auth) auth="$2"; shift 2 ;;
          *) err "unknown arg: $1"; return 1 ;;
        esac
      done
      [[ -z "$json_file" ]] && { err "ratio-sync fetch requires --json"; return 1; }
      call_cmd POST "/api/ratio_sync/fetch" --auth "$auth" --json "$json_file"
      ;;
    *)
      err "ratio-sync expects: channels|fetch"
      return 1
      ;;
  esac
}

