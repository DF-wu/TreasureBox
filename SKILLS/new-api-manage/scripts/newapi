models_cmd() {
  local sub="${1:-}"
  shift || true
  case "$sub" in
    list) models_list_cmd "$@" ;;
    search) models_search_cmd "$@" ;;
    get) models_get_cmd "$@" ;;
    create) models_create_cmd "$@" ;;
    update) models_update_cmd "$@" ;;
    delete) models_delete_cmd "$@" ;;
    missing) models_missing_cmd "$@" ;;
    sync)
      local sub2="${1:-}"
      shift || true
      case "$sub2" in
        preview) models_sync_preview_cmd "$@" ;;
        run) models_sync_run_cmd "$@" ;;
        *) err "models sync expects preview|run"; return 1 ;;
      esac
      ;;
    *) err "unknown models subcommand: $sub"; return 1 ;;
  esac
}

