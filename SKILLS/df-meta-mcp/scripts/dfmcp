#!/usr/bin/env bash
set -euo pipefail

ENDPOINT="${DF_METAMCP_ENDPOINT:-https://metamcp.dfder.tw/metamcp/chatbot/mcp}"
NAME="${DF_METAMCP_NAME:-dfmcp}"

if command -v mcporter >/dev/null 2>&1; then
  MCP_CMD=("$(command -v mcporter)")
elif command -v bunx >/dev/null 2>&1; then
  MCP_CMD=(bunx -y mcporter)
elif command -v npx >/dev/null 2>&1; then
  MCP_CMD=(npx -y mcporter)
else
  echo "Neither mcporter, bunx, nor npx is available in PATH" >&2
  exit 127
fi

usage() {
  cat <<'EOF2'
dfmcp - wrapper around mcporter for DF's MetaMCP endpoint

Usage:
  dfmcp list [mcporter list flags...]
  dfmcp schema [mcporter list flags...]
  dfmcp call <tool-or-selector> [mcporter call args...]
  dfmcp auth [mcporter auth args...]
  dfmcp config [mcporter config args...]
  dfmcp generate-cli [mcporter generate-cli args...]
  dfmcp inspect-cli [mcporter inspect-cli args...]
  dfmcp emit-ts [mcporter emit-ts args...]
  dfmcp daemon [mcporter daemon args...]
  dfmcp refresh

Environment overrides:
  DF_METAMCP_ENDPOINT  Override the default endpoint URL
  DF_METAMCP_NAME      Override the logical mcporter server name

Examples:
  dfmcp list --schema
  dfmcp schema --json
  dfmcp call github_mcp__get_me --output json
  dfmcp call github_mcp__search_repositories --args '{"query":"lilac mono"}' --output json
  dfmcp refresh
EOF2
}

selector_for_tool() {
  local input="$1"
  if [[ "$input" == http://* || "$input" == https://* ]]; then
    printf '%s\n' "$input"
    return 0
  fi
  if [[ "$input" == *.* ]]; then
    printf '%s\n' "$input"
    return 0
  fi
  printf '%s.%s\n' "$ENDPOINT" "$input"
}

run_mcporter() {
  exec "${MCP_CMD[@]}" "$@"
}

cmd="${1:-}"
case "$cmd" in
  list)
    shift
    run_mcporter list --http-url "$ENDPOINT" --name "$NAME" "$@"
    ;;
  schema)
    shift
    run_mcporter list --http-url "$ENDPOINT" --name "$NAME" --schema "$@"
    ;;
  call)
    shift
    tool="${1:-}"
    if [[ -z "$tool" ]]; then
      echo "missing tool name" >&2
      usage >&2
      exit 2
    fi
    shift
    selector="$(selector_for_tool "$tool")"
    run_mcporter call "$selector" "$@"
    ;;
  auth|config|generate-cli|inspect-cli|emit-ts|daemon)
    run_mcporter "$@"
    ;;
  refresh)
    shift || true
    SCRIPT_DIR="$(cd -- "$(dirname -- "$0")" && pwd)"
    exec python3 "$SCRIPT_DIR/sync_catalog.py" "$@"
    ;;
  -h|--help|help|"")
    usage
    ;;
  *)
    echo "unknown command: $cmd" >&2
    usage >&2
    exit 2
    ;;
esac
