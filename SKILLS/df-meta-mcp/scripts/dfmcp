#!/usr/bin/env bash
set -euo pipefail

ENDPOINT="https://metamcp.dfder.tw/metamcp/chatbot/mcp"
NAME="dfmcp"

if command -v mcporter >/dev/null 2>&1; then
  MCP_CMD=("$(command -v mcporter)")
elif command -v npx >/dev/null 2>&1; then
  MCP_CMD=(npx -y mcporter)
else
  echo "Neither mcporter nor npx is available in PATH" >&2
  exit 127
fi

usage() {
  cat <<'EOF'
dfmcp - wrapper around mcporter for DF's MetaMCP endpoint

Usage:
  dfmcp list [mcporter list flags...]
  dfmcp call <tool> [mcporter call args...]
  dfmcp refresh

Examples:
  dfmcp list --schema
  dfmcp call github_mcp__get_me --output json
  dfmcp call github_mcp__search_repositories --args '{"query":"lilac mono"}' --output json
  dfmcp refresh
EOF
}

cmd="${1:-}"
case "$cmd" in
  list)
    shift
    exec "${MCP_CMD[@]}" list --http-url "$ENDPOINT" --name "$NAME" "$@"
    ;;
  call)
    shift
    tool="${1:-}"
    if [[ -z "$tool" ]]; then
      echo "missing tool name" >&2
      usage >&2
      exit 2
    fi
    shift
    exec "${MCP_CMD[@]}" call "$ENDPOINT.$tool" "$@"
    ;;
  refresh)
    shift || true
    SCRIPT_DIR="$(cd -- "$(dirname -- "$0")" && pwd)"
    exec python3 "$SCRIPT_DIR/sync_catalog.py" "$@"
    ;;
  -h|--help|help|"")
    usage
    ;;
  *)
    echo "unknown command: $cmd" >&2
    usage >&2
    exit 2
    ;;
esac
